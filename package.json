{
  "name": "tatemd",
  "version": "0.1.0",
  "type": "module",
  "description": "Vertical-writing (tategaki) Markdown previewer & faithful PDF exporter (emaki / book)",
  "license": "MIT",
  "author": "torifonium",
  "homepage": "https://github.com/torifonium/tatemd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/torifonium/tatemd.git"
  },
  "bugs": {
    "url": "https://github.com/torifonium/tatemd/issues"
  },
  "keywords": [
    "markdown",
    "vertical-writing",
    "tategaki",
    "縦書き",
    "japanese",
    "typesetting",
    "pdf",
    "emaki",
    "puppeteer",
    "vivliostyle",
    "cli"
  ],
  "bin": {
    "tatemd": "bin/tatemd.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist-cli/core/markdown.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "tools/",
    "dist-cli/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build:cli"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.16.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
