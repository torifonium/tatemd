{
  "name": "tatemd-vscode",
  "displayName": "TATEmd — 縦書き Markdown プレビュー",
  "description": "Markdown を縦書きでプレビューする VSCode 拡張",
  "version": "0.0.1",
  "publisher": "torifonium",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tatemd.openPreview",
        "title": "TATEmd: 縦書きプレビューを開く"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "tatemd.openPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/markdown-it": "^14.1.2",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.4"
  }
}
