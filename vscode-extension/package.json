{
  "name": "tatemd-vscode",
  "displayName": "TATEmd — 縦書き Markdown プレビュー",
  "description": "Markdown を縦書きでプレビューし、絵巻 PDF（横長1枚）として書き出す VSCode 拡張",
  "version": "0.0.3",
  "publisher": "torifonium",
  "license": "MIT",
  "author": "torifonium",
  "icon": "icon.png",
  "galleryBanner": { "color": "#14130f", "theme": "dark" },
  "homepage": "https://github.com/torifonium/tatemd/tree/main/vscode-extension#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/torifonium/tatemd.git",
    "directory": "vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/torifonium/tatemd/issues"
  },
  "keywords": [
    "縦書き",
    "tategaki",
    "vertical",
    "vertical writing",
    "japanese",
    "markdown",
    "preview",
    "emaki",
    "pdf"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Visualization", "Formatters"],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "tatemd.openPreview",
        "title": "縦書きプレビューを開く",
        "category": "TATEmd",
        "icon": "$(open-preview)"
      },
      {
        "command": "tatemd.exportEmaki",
        "title": "絵巻 PDF を書き出す（横長1枚）",
        "category": "TATEmd",
        "icon": "$(book)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "tatemd.openPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "tatemd.exportEmaki",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node build.mjs"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/markdown-it": "^14.1.2",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.4"
  }
}
