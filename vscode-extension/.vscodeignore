# ソースコード・設定（パッケージに含めない）
src/
tsconfig.json
build.mjs
.vscodeignore

# ロックファイル（vsix には不要）
package-lock.json

# ビルド中間物（ソースマップは配布物に含めない）
**/*.map

# 依存パッケージ（out/ にバンドル済みのため不要）
node_modules/

# 掲載 README 用スクショは絶対 URL 参照なので vsix には同梱しない（icon.png は同梱する）
images/

# ルートの tatemd ソース（拡張には不要）
../src/
../index.html
../vite.config.ts
../package.json
../tsconfig.json
../.gitignore
../.eslintrc.cjs
../.prettierrc.json

# 含めるもの（参考）:
#   out/extension.js  … バンドル済みエントリ
#   media/vertical.css … 縦書き CSS
#   README.md / LICENSE … Marketplace 表示用
